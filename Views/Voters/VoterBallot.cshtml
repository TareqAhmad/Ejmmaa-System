@{
    ViewData["Title"] = "صندوق الاقتراع الإلكتروني - نظام إجماع";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Voters/VoterBallot.css" />
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold text-ejmaa">نظام إجماع الإلكتروني</h1>
        <p class="text-muted fs-5">صندوق الاقتراع الرقمي - اختر مرشحك عبر التعليم على مربع الاختيار</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10 col-md-12">
            <div class="card ballot-card p-4 p-md-5">

                <div class="step-content fade-in" id="stepBallot">
                    <div class="text-center mb-5">
                        <h2 class="fw-bold text-dark">ورقة الاقتراع الإلكترونية</h2>
                        <p class="text-muted fs-6">يرجى تحديد خياراتك المفضلة بالنقر مباشرة على كرت المرشح لتفعيل علامة الصح</p>
                    </div>

                    <div class="mb-5">
                        <h4 class="section-divider fs-4">أولاً: منصب رئيس المجلس <span class="fs-6 text-muted fw-normal">(تعليم مربع واحد فقط)</span></h4>
                        <div class="row g-4" id="presidentsList">
                            <div class="col-md-4 col-sm-6">
                                <div class="card candidate-card text-center" onclick="selectPresident(101, 'المهندس أحمد صالح العبد الله', this)">
                                    <div class="custom-checkbox-container">
                                        <input type="checkbox" class="custom-checkbox pres-check" id="chkPres101">
                                    </div>
                                    <img src="~/images/logo.jpg" class="card-img-top candidate-img rounded-3 mb-2" alt="أحمد صالح">
                                    <h5 class="fw-bold mb-1 fs-6">المهندس أحمد صالح العبد الله</h5>
                                    <span class="text-muted fs-7">كتلة التطوير والتحديث</span>
                                </div>
                            </div>
                            <div class="col-md-4 col-sm-6">
                                <div class="card candidate-card text-center" onclick="selectPresident(102, 'الدكتور محمد حسن سلامة', this)">
                                    <div class="custom-checkbox-container">
                                        <input type="checkbox" class="custom-checkbox pres-check" id="chkPres102">
                                    </div>
                                    <img src="~/images/logo.jpg" class="card-img-top candidate-img rounded-3 mb-2" alt="محمد سلامة">
                                    <h5 class="fw-bold mb-1 fs-6">الدكتور محمد حسن سلامة</h5>
                                    <span class="text-muted fs-7">كتلة العهد والوفاء</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-5">
                        <h4 class="section-divider fs-4">ثانياً: أعضاء الهيئة الإدارية <span class="fs-6 text-muted fw-normal">(تعليم حتى 3 مربعات كحد أقصى)</span></h4>
                        <div class="row g-4" id="membersList">
                            <div class="col-md-4 col-sm-6">
                                <div class="card candidate-card text-center" onclick="selectMember(201, 'خالد وليد الشبيكات', this)">
                                    <div class="custom-checkbox-container">
                                        <input type="checkbox" class="custom-checkbox member-check" id="chkMember201">
                                    </div>
                                    <img src="~/images/logo.jpg" class="card-img-top candidate-img rounded-3 mb-2" alt="خالد وليد">
                                    <h5 class="fw-bold mb-1 fs-6">خالد وليد الشبيكات</h5>
                                    <span class="text-muted fs-7">مرشح مستقل</span>
                                </div>
                            </div>
                            <div class="col-md-4 col-sm-6">
                                <div class="card candidate-card text-center" onclick="selectMember(202, 'عمر نايف الفايز', this)">
                                    <div class="custom-checkbox-container">
                                        <input type="checkbox" class="custom-checkbox member-check" id="chkMember202">
                                    </div>
                                    <img src="~/images/logo.jpg" class="card-img-top candidate-img rounded-3 mb-2" alt="عمر نايف">
                                    <h5 class="fw-bold mb-1 fs-6">عمر نايف الفايز</h5>
                                    <span class="text-muted fs-7">مرشح مستقل</span>
                                </div>
                            </div>
                            <div class="col-md-4 col-sm-6">
                                <div class="card candidate-card text-center" onclick="selectMember(203, 'فيصل حابس الدعجة', this)">
                                    <div class="custom-checkbox-container">
                                        <input type="checkbox" class="custom-checkbox member-check" id="chkMember203">
                                    </div>
                                    <img src="~/images/logo.jpg" class="card-img-top candidate-img rounded-3 mb-2" alt="فيصل حابس">
                                    <h5 class="fw-bold mb-1 fs-6">فيصل حابس الدعجة</h5>
                                    <span class="text-muted fs-7">مرشح مستقل</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <button type="button" onclick="validateAndGoToSummary()" class="btn btn-ejmaa btn-lg px-5 shadow-sm">
                            الانتقال لملخص ورقة الاقتراع <i class="bi bi-arrow-left ms-2"></i>
                        </button>
                    </div>
                </div>

                <div class="step-content d-none fade-in" id="stepSummary">
                    <div class="text-center mb-5">
                        <i class="bi bi-clipboard-check text-warning mb-3" style="font-size: 4rem;"></i>
                        <h2 class="fw-bold text-dark">تأكيد خياراتك الانتخابية</h2>
                        <p class="text-muted fs-6">الرجاء التحقق من خياراتك النهائية بعناية قبل اعتماد وإرسال صوتك</p>
                    </div>

                    <div class="row justify-content-center mb-5">
                        <div class="col-md-8">
                            <div class="p-4 mb-4 rounded-3 bg-light border-start border-primary border-4 shadow-sm">
                                <span class="text-muted d-block fs-7 mb-1">اختيارك لرئاسة المجلس:</span>
                                <h3 class="fw-bold text-dark mb-0" id="selectedPresidentSummary">لم يتم اختيار رئيس بعد</h3>
                            </div>

                            <div class="p-4 rounded-3 bg-light border-start border-success border-4 shadow-sm">
                                <span class="text-muted d-block fs-7 mb-2">اختياراتك لعضوية الهيئة الإدارية:</span>
                                <ul class="list-unstyled fw-bold text-dark fs-5 mb-0" id="selectedMembersSummary">
                                    <li class="text-danger">• لم يتم اختيار أعضاء بعد</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-3 justify-content-center">
                        <button type="button" onclick="backToBallot()" class="btn btn-outline-secondary btn-lg px-4">
                            تعديل الخيارات <i class="bi bi-pencil-square ms-2"></i>
                        </button>
                        <button type="button" onclick="submitFinalVote()" class="btn btn-success btn-lg px-5 shadow">
                            تأكيد التصويت النهائي <i class="bi bi-check2-square ms-2"></i>
                        </button>
                    </div>
                </div>

                <div class="step-content d-none fade-in" id="stepSuccess">
                    <div class="text-center py-5">
                        <i class="bi bi-check-circle-fill text-success mb-4" style="font-size: 6rem;"></i>
                        <h2 class="fw-bold text-dark mb-3">تم تسجيل وصيانة صوتك بنجاح وسرية تامّة!</h2>
                        <p class="text-muted fs-5 mb-4">شكراً لمشاركتك الفعّالة والأمينة في صنع القرار.</p>
                        
                        <div class="bg-light p-3 rounded-3 border mb-4 d-inline-block">
                            <span class="text-muted d-block fs-7">الرقم المرجعي المشفر للصوت</span>
                            <strong class="text-dark fs-4" id="voteReference">EJ-2026-V88</strong>
                        </div>
                        
                        <p class="text-muted fs-7">تلقائياً، سيعود النظام إلى شاشة الدخول للناخب التالي خلال ثوانٍ معدودة...</p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/JS/apiService.js"></script>
    <script src="~/JS/Voters/VoterBallot.js"></script>
}