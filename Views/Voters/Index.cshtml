@{
    ViewData["Title"] = "بوابة المقترع - تسجيل الدخول";
}

@section Styles {  
    <link rel="stylesheet" href="~/css/Voters/index.css" />
}

<div class="container-fluid full-screen-container p-0 vh-100">
    <div class="row no-gutters h-100 mx-0">
        
        <div class="col-md-6 d-none d-md-block login-image-column bg-ejmaa text-white position-relative">
            <div class="login-image-container d-flex flex-column align-items-center justify-content-center h-100 p-5">
                <div class="text-center brand-overlay">
                    <img src="~/images/logo.jpg" alt="إجماع - نظام إدارة الانتخابات" class="img-fluid mb-4" style="max-height: 38rem; filter: drop-shadow(0rem 1rem 2rem rgba(0,0,0,0.3));">
                    
                    <h1 class="display-5 fw-bold mb-3">نظام إجماع الإلكتروني</h1>
                    <p class="fs-3 fw-light text-light mb-4">المنصة الآمنة والموثوقة لإدارة انتخابات العشائر والجمعيات بكل شفافية ونزاهة.</p>
                    <span class="fs-4 text-white-50 d-block"> &copy; 2026 Ejmaa Solutions. جميع الحقوق محفوظة.</span>
                </div>
            </div>
        </div>            

        <div class="col-md-6 col-12 login-form-column d-flex align-items-center justify-content-center bg-white">
            <div class="login-form-wrapper border shadow-lg rounded-4 w-100 overflow-hidden" style="max-width: 50rem;">
                
                <div class="voter-header-box p-4 text-center text-white">
                    <i class="bi bi-envelope-paper-heart fs-1 mb-2"></i>
                    <h3 class="fw-bold mb-0">بوابة الاقتراع والتصويت</h3>
                    <p class="text-white-50 small mb-0">صوتك أمانة.. مشاركتك تصنع الفارق</p>
                </div>

                <div class="p-5">
                    @* شعار صغير للشاشات الصغيرة (يظهر فقط في الموبايل) *@
                    <div class="text-center d-md-none mb-4">
                         <h1 class="fw-bold text-ejmaa">إجماع</h1>
                         <p class="text-muted">بوابة المقترع الذاتية</p>
                    </div>

                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-dark">ابدأ التصويت الآن</h2>
                        <p class="text-muted small">أدخل الرقم الوطني ورمز التحقق المستلم من المشرف للدخول</p>
                    </div>

                    <form id="voterLoginForm">
                        <div class="mb-4">
                            <label for="voterNationalId" class="form-label fw-bold small">الرقم الوطني للمقترع</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-person-badge text-muted"></i></span>
                                <input type="text" class="form-control text-center fs-5 p-3 border-start-0" id="voterNationalId" placeholder="99XXXXXXXX" maxlength="10" required>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="voterOtp" class="form-label fw-bold small">رمز التحقق (OTP)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-key text-muted"></i></span>
                                <input type="text" class="form-control text-center otp-input fs-5 p-3 border-start-0" id="voterOtp" placeholder="••••••" maxlength="6" required>
                            </div>
                        </div>

                        <button type="button" id="btnVoterLogin" class="btn btn-ejmaa w-100 fs-5 shadow-sm text-white p-3 fw-bold">
                           دخول لبدء التصويت السري <i class="bi bi-arrow-left ms-2"></i>
                        </button>
                    </form>

                    <p class="text-danger mt-3 text-center d-none" id="MsgVoterError">الرقم الوطني أو رمز التحقق غير صحيح، يرجى المحاولة مجدداً.</p>
                    <div class="text-center mt-4 small text-muted">الرجاء مراجعة مشرف المركز إذا واجهت مشكلة في الدخول.</div>
                </div>
            </div>
        </div>

    </div>
</div>

@section scripts {
    <script src="~/JS/apiService.js"></script>
    <script src="~/JS/Voters/index.js"></script>
}