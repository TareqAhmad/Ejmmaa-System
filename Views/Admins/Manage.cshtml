@model Ejmmaa.Models.ViewModels.ClanViewModel;

@{
    ViewData["Title"] = "إدارة العشيرة الداخلية - إجماع";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/SuperAdmin/dashboard.css" />
    <link rel="stylesheet" href="~/css/Admins/Manage.css" />
}

<div class="dashboard-wrapper-layout">
    <aside class="sidebar-wrapper">
        <div class="sidebar-header"><h4 class="text-gold fw-bold">لجنة العشيرة</h4></div>
        <nav class="sidebar-nav">
            <a href="#" class="nav-item active"><i class="bi bi-speedometer2"></i> لوحة التحكم</a>
            <a href="#" class="nav-item"><i class="bi bi-diagram-3"></i>الاقسام</a>
            <a href="#" class="nav-item"><i class="bi bi-people"></i>الأفراد</a>
            <a href="#" class="nav-item"><i class="bi bi-gear"></i> المرشيحن</a>
            <a href="#" class="nav-item"><i class="bi bi-gear"></i> الناخبين</a>
           <div class="nav-divider"></div>
           <a href="/" class="nav-item text-danger"><i class="bi bi-box-arrow-right"></i> تسجيل الخروج</a>
        </nav>
    </aside>

    <main class="main-content-dashboard">
        <header class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">لوحة إدارة الهيئة العامة</h2>
            <button class="btn btn-gold" data-bs-toggle="modal" data-bs-target="#addMemberModal">
                <i class="bi bi-plus-lg"></i> إضافة فرد جديد
            </button>
        </header>

        <div class="row g-4">
            <div class="col-12">
                <div class="card p-3 shadow-sm">
                    <h5 class="fw-bold mb-3 text-primary"><i class="bi bi-info-circle"></i> معلومات العشيرة</h5>
                    <table id="ClanInfoTable" class="table ejmaa-table w-100">
                        <thead class="table-light">
                            <tr>
                                <th>رمز العشيرة</th>
                                <th>الاسم</th>
                                <th>الحالة</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>@Model.ClanId</td>
                                <td>@Model.ClanName</td>
                                <td><span class="badge bg-success">نشط</span></td>
                                <td><button class="btn btn-sm btn-outline-primary">تعديل</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-12">
                <div class="card p-3 shadow-sm">
                    <h5 class="fw-bold mb-3"><i class="bi bi-diagram-3"></i> أقسام العشيرة</h5>
                    <table id="SectionsTable" class="table ejmaa-table w-100">
                        <thead class="table-light">
                            <tr>
                                <th>CheckBox</th>
                                <th>القسم</th>
                                <th>عدد الأفراد</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody id="ClanSectionsBody">
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-12">
                <div class="content-card p-3 shadow-sm">
                    <h5 class="fw-bold mb-3"><i class="bi bi-people"></i> جدول الأفراد</h5>
                    <table id="membersTable" class="table ejmaa-table w-100">
                        <thead class="table-light">
                            <tr>
                                <th>الاسم الكامل</th>
                                <th>الرقم الوطني</th>
                                <th>رقم الهاتف</th>
                                <th>تاريخ الميلاد</th>
                                <th>الجنس</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody id="membersTableBody">
                            <tr><td>طارق الشبيكات</td><td>111222333</td><td>فخذ أ</td><td><button class="btn btn-sm btn-info">تعديل</button></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/JS/apiService.js"></script>
    <script src="~/JS/Admins/Manage.js"></script>
}