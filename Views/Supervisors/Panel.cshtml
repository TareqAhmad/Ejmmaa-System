@{
    ViewData["Title"] = "شاشة مراقبة الصناديق والتحقق - إجماع";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Supervisors/Panel.css" />
}

<div class="supervisor-container py-4">
    <div class="container">
        
        <header class="supervisor-header d-flex justify-content-between align-items-center mb-4 p-3 bg-white rounded-4 shadow-sm border-start border-primary border-4">
            <div class="d-flex align-items-center">
                <div class="supervisor-avatar bg-primary text-white rounded-circle me-3">
                    <i class="bi bi-person-badge-fill fs-4"></i>
                </div>
                <div class="text-end pe-2">
                    <h4 class="fw-bold text-dark mb-1">بوابة مراقب الصندوق</h4>
                    <p class="text-muted small mb-0">مرحباً بك في اللجنة الانتخابية | صندوق رقم (1)</p>
                </div>
            </div>
            <a href="/" class="btn btn-outline-danger btn-sm fw-bold"><i class="bi bi-box-arrow-right me-1"></i> خروج</a>
        </header>

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                    <h4 class="fw-bold text-dark mb-3"><i class="bi bi-search text-primary me-2"></i>البحث عن مقترع</h4>
                    <p class="text-muted small mb-4">ابحث عن اسم الناخب بالرقم الوطني، الاسم، أو رقم الهاتف للتحقق من قيده الانتخابي.</p>
                    
                    <div class="input-group mb-4">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-person-vcard text-muted"></i></span>
                        <input type="text" id="searchVoterInput" class="form-control fs-5 p-3 border-start-0 text-center" placeholder="أدخل الرقم الوطني أو رقم الهاتف..." />
                        <button class="btn btn-primary px-4 fw-bold" id="btnSearchVoter">بحث سريع</button>
                    </div>

                    <div id="voterResultBox" class="p-4 rounded-3 border bg-light-blue d-none">
                        <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom border-secondary-subtle">
                            <span class="badge bg-success fs-8 px-3 py-2 rounded-pill"><i class="bi bi-check-circle-fill me-1"></i> يحق له الانتخاب</span>
                            <h5 class="fw-bold mb-0 text-dark">بيانات المقترع</h5>
                        </div>
                        
                        <div class="voter-info-grid text-end">
                            <p class="mb-2"><strong>الاسم الكامل:</strong> <span id="lblVoterName">أحمد محمد عبد الله الشبيكات</span></p>
                            <p class="mb-2"><strong>الرقم الوطني:</strong> <span id="lblVoterNationalId">9901020304</span></p>
                            <p class="mb-2"><strong>رقم الهاتف المعتمد:</strong> <span id="lblVoterPhone" dir="ltr">+962 79 123 4567</span></p>
                            <p class="mb-0"><strong>حالة التصويت:</strong> <span class="badge bg-warning text-dark" id="lblVoteStatus">لم يصوت بعد</span></p>
                        </div>

                        <hr class="my-3">

                        <div class="text-center">
                            <button class="btn btn-success w-100 p-3 fs-5 fw-bold" id="btnGenerateOTP">
                                <i class="bi bi-shield-fill-check me-1"></i> توليد وإرسال رمز التحقق (OTP)
                            </button>
                            <p class="text-muted small mt-2 mb-0">سيتم إرسال رمز الـ OTP المكون من 4 أرقام برسالة نصية إلى هاتف الناخب فوراً.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card border-0 shadow-sm rounded-4 p-4 text-center mb-4 text-white bg-dark-blue">
                    <i class="bi bi-pie-chart-fill fs-1 text-warning mb-2"></i>
                    <h3 class="fw-bold text-warning mb-1">إحصائيات الصندوق</h3>
                    <p class="text-white-50 small mb-4">متابعة فورية لنسب الحضور في لجنتك</p>
                    
                    <div class="row g-2">
                        <div class="col-6 border-start border-white-50">
                            <h3 class="fw-bold text-white mb-0">145</h3>
                            <p class="text-white-50 mb-0 small">من اقترعوا</p>
                        </div>
                        <div class="col-6">
                            <h3 class="fw-bold text-white mb-0">450</h3>
                            <p class="text-white-50 mb-0 small">إجمالي المسجلين</p>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <h5 class="fw-bold text-dark mb-3"><i class="bi bi-clock-history text-muted me-2"></i>آخر عمليات التحقق</h5>
                    <div class="verified-list">
                        <div class="verified-item d-flex justify-content-between align-items-center p-3 rounded-3 mb-2 border">
                            <span class="text-muted small">منذ دقيقتين</span>
                            <div class="text-end">
                                <h6 class="fw-bold mb-0 small">سعيد خالد الفايز</h6>
                                <span class="badge bg-success-light text-success fs-9">تم إرسال OTP</span>
                            </div>
                        </div>
                        <div class="verified-item d-flex justify-content-between align-items-center p-3 rounded-3 mb-2 border">
                            <span class="text-muted small">منذ 5 دقائق</span>
                            <div class="text-end">
                                <h6 class="fw-bold mb-0 small">يوسف علي بني صخر</h6>
                                <span class="badge bg-secondary-light text-secondary fs-9">اكتمل التصويت</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section scripts {
    <script src="~/JS/Supervisors/Panel.js"></script>
}